<?xml version="1.0" encoding="utf-8"?>
<!--
  Simplified URDF for 2-Joint GELLO Arm (Gravity Compensation)

  Only joints 1 and 2 for testing with 2 motors.
-->
<robot name="gello_2joint">

  <!-- ==================== BASE ==================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00008"/>
    </inertial>
  </link>

  <!-- ==================== JOINT 1: SHOULDER PAN ==================== -->
  <!-- Motor: XL330-M288-T (18g) -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="0.000008" ixy="0" ixz="0" iyy="0.000008" iyz="0" izz="0.000004"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.0235" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="0.5" velocity="6.28"/>
  </joint>

  <!-- ==================== JOINT 2: SHOULDER LIFT ==================== -->
  <!-- Motor: XM430-W350-T (82g) — UPGRADED -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.155"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.000015"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.04" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="4.1" velocity="3.14"/>
  </joint>

</robot>